# ============================================================
# SÉCURITÉ - Bloque l'accès HTTP direct aux fichiers sensibles
# ============================================================
# Protection directe Apache (sans dépendance à mod_rewrite)
<FilesMatch "^\.env(\..+)?$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.git">
    Require all denied
</FilesMatch>

<FilesMatch "^\.htaccess$">
    Require all denied
</FilesMatch>

# Bloque l'accès direct aux fichiers PHP autres que index.php
<FilesMatch "^(?!index\.php$).+\.php$">
    Require all denied
</FilesMatch>

# Bloquer les fichiers sensibles supplémentaires
<FilesMatch "\.(log|json|md|sh|sql|yml|yaml|lock|xml)$">
    Require all denied
</FilesMatch>

# ===============================================
# SÉCURITÉ - Désactive le listing des répertoires
# ===============================================
Options -Indexes

# =================================
# ROUTING - Redirige vers index.php
# =================================
# Redirige vers index.php si pas de fichier réel ciblé
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>